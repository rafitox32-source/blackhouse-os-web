# Copia este archivo a ".env" para desarrollo local con dev-server.js.
# En producción (Vercel) estas mismas variables se configuran en el
# dashboard del proyecto, nunca en un archivo .env subido al repo.

# Llave de servicio de Supabase (secreta, salta RLS). La usan api/db.js
# y api/login.js del lado del servidor. NUNCA exponerla al navegador.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-llave-service-role

# Llave anon (publica, respeta RLS). La entrega api/config.js al navegador
# para el tracking, la recuperacion de contraseña, etc.
SUPABASE_ANON_KEY=tu-llave-anon

# Secreto para firmar los JWT de sesion de panel.html/panel-vendedor.html/
# panel-tecnico.html. Si falta, api/db.js cae a SUPABASE_KEY (ver ahi el porque).
JWT_SECRET=un-secreto-largo-y-unico
